        {
          "name": "Create Company Internship",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.data?.id) {",
                  "  pm.collectionVariables.set('company_internship_id', json.data.id);",
                  "  pm.collectionVariables.set('internship_id', json.data.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{company_token}}", "type": "string" }] },
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Postman Backend Internship\",\n  \"description\": \"Build Laravel APIs and React interfaces for the internship platform.\",\n  \"requirements\": \"PHP, Laravel, REST APIs\",\n  \"location\": \"Cairo\",\n  \"type\": \"remote\",\n  \"starts_at\": \"2026-07-01\",\n  \"ends_at\": \"2026-09-30\",\n  \"skills\": [{{skill_id}}]\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{api_url}}/company/internships", "host": ["{{api_url}}"], "path": ["company", "internships"] }
          }
        },
        {
          "name": "Update Internship",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{company_token}}", "type": "string" }] },
            "method": "PUT",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Postman Backend Internship Updated\",\n  \"description\": \"Updated internship description from Postman.\",\n  \"requirements\": \"Laravel, API testing, React\",\n  \"location\": \"Remote\",\n  \"type\": \"hybrid\",\n  \"starts_at\": \"2026-07-15\",\n  \"ends_at\": \"2026-10-15\",\n  \"skills\": [{{skill_id}}]\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{api_url}}/internships/{{company_internship_id}}", "host": ["{{api_url}}"], "path": ["internships", "{{company_internship_id}}"] }
          }
        },
        {
          "name": "Archive Internship",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{company_token}}", "type": "string" }] },
            "method": "PATCH",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": { "raw": "{{api_url}}/internships/{{company_internship_id}}/archive", "host": ["{{api_url}}"], "path": ["internships", "{{company_internship_id}}", "archive"] }
          }
        },
        {
          "name": "Archived Company Internships",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{company_token}}", "type": "string" }] },
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": { "raw": "{{api_url}}/company/internships/archived", "host": ["{{api_url}}"], "path": ["company", "internships", "archived"] }
          }
        },
        {
          "name": "Create Open Internship For Application Flow",
          "description": "Creates a fresh open internship after the archive request so later student application and match-score requests have an open target.",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.data?.id) {",
                  "  pm.collectionVariables.set('open_internship_id', json.data.id);",
                  "  pm.collectionVariables.set('internship_id', json.data.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{company_token}}", "type": "string" }] },
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Postman Open Internship\",\n  \"description\": \"Open internship used by the application and match-score slices.\",\n  \"requirements\": \"Laravel, communication, problem solving\",\n  \"location\": \"Cairo\",\n  \"type\": \"remote\",\n  \"starts_at\": \"2026-08-01\",\n  \"ends_at\": \"2026-10-31\",\n  \"skills\": [{{skill_id}}]\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{api_url}}/company/internships", "host": ["{{api_url}}"], "path": ["company", "internships"] }
          }
        },
        {
          "name": "Delete Internship",
          "description": "Destructive cleanup request. Run after dependent application tests.",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{company_token}}", "type": "string" }] },
            "method": "DELETE",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": { "raw": "{{api_url}}/internships/{{company_internship_id}}", "host": ["{{api_url}}"], "path": ["internships", "{{company_internship_id}}"] }
          }
        }
      ]
